# Read the Room — environment
# Copy to .env.local and fill in. NEVER commit .env.local.

# Which LLM powers the app:
#   groq      -> free, fast, for the live demo (default when GROQ_API_KEY is set)
#   anthropic -> Claude, best quality, for the recorded demo video
#   demo      -> offline canned responses (demo-safe mode; no key needed)
LLM_PROVIDER=demo

# Groq (free, no credit card): https://console.groq.com -> API Keys
GROQ_API_KEY=
# Optional model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (optional, for the polished recorded demo)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
